// ─────────────────────────────────────────────────────────────────────────────
// nextflow.config  —  memory-safe settings for ~7 GB RAM / 20 samples
// ─────────────────────────────────────────────────────────────────────────────

// Cap Nextflow's own JVM so it doesn't eat your RAM
env {
    NXF_OPTS = '-Xms256m -Xmx512m'
}

// Global defaults
process {

    // Retry on OOM kill (exit 137) or generic failure (exit 1)
    // Terminate on anything else so errors don't silently pile up
    errorStrategy = {
        task.exitStatus in [1, 137] && task.attempt <= 3
            ? 'retry'
            : 'terminate'
    }
    maxRetries = 3

    // ── Light processes (can overlap) ─────────────────────────────────────
    withName: 'DOWNLOAD_REFERENCE' {
        memory   = '512 MB'
        cpus     = 1
        maxForks = 1
    }

    withName: 'FASTQC_RAW|FASTQC_TRIMMED' {
        memory   = { 512.MB * task.attempt }
        cpus     = 1
        maxForks = 3     // 3 × 512 MB = 1.5 GB max simultaneous
    }

    withName: 'FASTP' {
        memory   = { 1.GB * task.attempt }
        cpus     = 2
        maxForks = 2     // 2 × 1 GB = 2 GB max simultaneous
    }

    withName: 'MULTIQC_RAW|MULTIQC_TRIMMED' {
        memory   = { 512.MB * task.attempt }
        cpus     = 1
        maxForks = 1
    }

    // ── Heavy processes (strict one-at-a-time) ────────────────────────────
    withName: 'SNIPPY' {
        memory   = { 2.GB * task.attempt }   // 2 GB → 4 GB → 6 GB on retries
        cpus     = 2
        maxForks = 1     // CRITICAL: never run two SNIPPY jobs together
    }

    withName: 'SNIPPY_CORE' {
        memory   = { 3.GB * task.attempt }
        cpus     = 2
        maxForks = 1
    }

    withName: 'IQTREE' {
        memory   = { 3.GB * task.attempt }
        cpus     = 2
        maxForks = 1
    }
}

// ── Execution report (optional but useful) ────────────────────────────────────
report {
    enabled   = true
    file      = "results/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "results/pipeline_timeline.html"
    overwrite = true
}
